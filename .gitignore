# Session memory buffer (local only — harness/hook scratch, never commit)
.remember/

# Python (data analysis: pandas / openpyxl / jupyter)
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/
*.egg-info/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
*.tsbuildinfo

# Generated pipeline artifacts (regenerated from sources; never commit)
intermediate/*
!intermediate/.gitkeep
output/*
!output/.gitkeep
semantic-match/*
!semantic-match/.gitkeep
research/*
!research/.gitkeep

# Env / secrets
.env
.env.*

# OS / editor
.DS_Store
